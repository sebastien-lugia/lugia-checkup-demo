# Copier ce fichier en .env.local et compléter les valeurs.
# .env.local est ignoré par git (cf .gitignore).

# URL du backend FastAPI
# - En local : http://localhost:8000
# - En production (Vercel) : https://lugia-checkup-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL Calendly pour les CTA "En parler avec Lugia" / "Prendre rendez-vous"
# - Surchargeable côté Vercel / Render dans les Environment Variables
# - Si absent, fallback sur le placeholder dans lib/v3/links.ts
# NEXT_PUBLIC_LUGIA_CALENDLY_URL=https://calendly.com/sebastien-lugia/30min

# Email de contact Lugia (fallback si Calendly indisponible)
# NEXT_PUBLIC_LUGIA_CONTACT_EMAIL=sebastien@lugia.fr
