# Dependencies
node_modules/

# Next.js
.next/
out/
build/

# Production
*.local

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env locaux
.env*.local

# Misc
.DS_Store
*.pem

# tsbuildinfo (cache incremental tsc — pas a versionner)
tsconfig.tsbuildinfo
*.tsbuildinfo

# Artefacts de compilation tsc — les sources sont en .ts/.tsx, les .js emis
# a cote ne doivent jamais etre versionnes (cf nettoyage tache #28). On cible
# uniquement les dossiers source ; next.config.js / postcss.config.js (racine)
# restent versionnes.
/lib/**/*.js
/components/**/*.js
/app/**/*.js
/tailwind.config.js
